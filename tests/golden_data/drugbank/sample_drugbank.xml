    <drugbank-id primary="true">DB00818</drugbank-id>
    <drugbank-id>APRD00382</drugbank-id>
    <name>Propofol</name>
    <description>Propofol is an intravenous anesthetic agent used for induction and maintenance of general anesthesia.</description>
    <mechanism-of-action>Propofol acts on GABA-A receptors to potentiate the inhibitory effect of GABA, leading to sedation and anesthesia.</mechanism-of-action>
    <pharmacodynamics>Propofol produces rapid onset of anesthesia with smooth recovery.</pharmacodynamics>
    <categories>
      <category>
        <name>Anesthetics, Intravenous</name>
      </category>
      <category>
        <name>Hypnotics and Sedatives</name>
      </category>
    </categories>
