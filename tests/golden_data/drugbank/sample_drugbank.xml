  <drug type="biotech" created="2007-07-11" updated="2024-01-01">
    <drugbank-id primary="true">DB06372</drugbank-id>
    <name>Sugammadex</name>
    <description>Sugammadex is a modified gamma-cyclodextrin used to reverse neuromuscular blockade induced by rocuronium or vecuronium.</description>
    <mechanism-of-action>Sugammadex encapsulates rocuronium and vecuronium molecules, forming a complex that prevents binding to nicotinic receptors.</mechanism-of-action>
    <pharmacodynamics>Sugammadex provides rapid reversal of neuromuscular blockade.</pharmacodynamics>
